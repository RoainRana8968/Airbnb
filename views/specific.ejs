<%- layout("./boilerpate.ejs") %>
    <body>
            <div class="offset-4">
                <h1>Specific detail....</h1>
                <div class="card show-img">
                    <img class="card-img-top" src="<%=specific.image.url%>">
                    <p>
                        <%= specific.description%>
                    </p>
                    <p>
                        <%=specific.location%>
                    </p>
                    <p>
                        <%=specific.country%>
                    </p>
                    <%if(curruser&&specific.owner&&specific.owner._id.equals(curruser._id)){%>
                        <form method="get" action="http://localhost:8080/specific/<%=specific._id%>/edit">
                            <button>Edit info</button>
                        </form>
                        <%}%>
                </div>
                <form method="post" action="http://localhost:8080/delete/<%= specific._id %>?_method=DELETE">
                    <!-- <button type="submit">Delete</button> -->
                </form>
            </div>
            <br>
            <br>
            <hr>
            <br>
            <br>

            <div class="col-8 offset-2 row-9">
                <h2>Leave ur review here</h2>
                <form method="post" class="form  row needs-validation" novalidate
                    action="http://localhost:8080/listings/<%=specific._id%>/review">
                    <div class="mb-3">
                        <input class="form-control" placeholder="Enter your review here" type="text" required>

                        <div class="valid-feedback">
                            Looks good!
                        </div>

                        <div class="invalid-feedback">
                            Please provide a valid review.
                        </div>
                    </div>
                    <br>
                    <div>
                        <span>Rating:</span>
                        <fieldset class="starability-slot">
                            <legend>First rating:</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked
                                aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>

                    <div class="mb-3">
                        <!--  when we submit form 
            review[rating] will be sent as 
            review:{
  rating: value of input range
            } -->
                        <textarea placeholder="Enter your comment" rows="4" cols="10" name="review[comment]" type="text"
                            class="form-control" value="enter comment here" required></textarea>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            Please provide a valid review.
                        </div>
                    </div>

                    <div>
                        <button type="submit" class="btn-dark btn">Submit review</button>
                    </div>
                </form>
            </div>
           
            <!-- //row uses internally flexbox and flex-wrap  mt-5 is used for margin top -->
             <%if(specific.reviews.length>0){%>
                          <div class=" offset-2 row gap-3">
                 <div>
                <hr>
                <h2>Reviews:</h2>
            </div>
                <% for(let i=0;i<specific.reviews.length;i++){ %>
                    <div class="card colm-6 mb-3" style="width: 18rem;">
                        <!-- // colm-6 dfined the width of card and gap-3 is used for gap between two cards -->
                        <div class="card-body">
                            <b>
                                <%=specific.reviews[i].owner.username%>
                            </b>
                            <h5 class="card-title">
                                <%=specific.title%>
                            </h5>
                            <h5 class="card-title">
                                <%=specific.reviews[i].rating%>
                                 <p class="starability-result" data-rating="<%=specific.reviews[i].rating%>">
    Rated: 3 stars
  </p>
                            </h5>
                            <p class="card-text">
                                <%=specific.reviews[i].comment%>
                            </p>
                            <a href="#" class="btn btn-primary">Go somewhere</a>
                            <% if(curruser && specific.owner && specific.owner._id &&
                                specific.owner._id.equals(curruser._id)){ %>
                                <form
                                    action="http://localhost:8080/listings/<%=specific._id%>/delete/<%=specific.reviews[i]._id%>"
                                    method="POST">
                                    <button type="submit" class="btn-dark btn">Delete review</button>
                                </form>
                                <% } %>
                        </div>
                    </div>

                    <% } %>
            </div>
            <%}%>
            <hr>
            <div id="map" style="height: 400px;border-radius:20px;" class="offset-2 col-8"></div>
            <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
            // will acts a global script
          <script>
    const listing = <%- JSON.stringify(specific.geometry.coordinates) %>;
</script>
            <script src="/js/script.js"></script>
            <script src="/js/map.js"></script>
            
    </body>

