<%- layout("./boilerpate.ejs") %>

    <body>
        
        <!-- validation feedback and invalid-feedbackis added with required keyword with input tag
        so that if user tries to submit form without filling any input then it will show error message and form will not be 
        submitted until user fills all the input fields with valid data. to use these properties we need to run its js code as well -->
        a
            <div class="col-8 offset-2 row-9">
                <form method="post" action="http://localhost:8080/edit/<%=id%>/form?_method=PATCH"
                    class="needs-validation" novalidate enctype="multipart/form-data">
                    <h1>Edit details</h1>

                    <div>
                        <label for="title" class="form-label"></label>
                        <input placeholder="enter title" name="title" type="text" class="form-control" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            enter valid input
                        </div></div>
                        <br>

                        <div>
                            <textarea placeholder="Enter description" rows="4" cols="10" name="description" type="text"
                                class="form-control" required>Enter Description</textarea>

                            <div class="invalid-feedback">
                                enter valid input
                            </div>
                        </div>
                        <br>
                        <!-- <div>
                            <img src="<%=updatedurl%>">
                        </div> -->
                        <br>
                        <div>
                            <input placeholder="enter Image url Link" name="image" class="form-control" type="file" >
                        </div>
                        <br>

                        <div>
                             <label for="number" class="number fomr-label"></label>
                            <input name="price" placeholder="enter price" type="number" class="form-control" required>
                            <div class="invalid-feedback">
                                enter valid input
                            </div>

                        </div>
                        <br>
                        <div>
                            <input placeholder="Enter Country" name="country" type="text" class="form-control" required>
                            <div class="invalid-feedback">
                                enter valid country
                            </div>
                        </div>

                        <br>

                        <div>
                            <input placeholder="Enter location" name="location" type="text" class="form-control"
                                required>
                            <div class="invalid-feedback">
                                enter valid location
                            </div>
                        </div>
                        >
                        <br>

                        <button type=" submit">SUbmit</button>
                </form>
            </div>
            <script src="/js/script.js"></script>
    </body>

